LANGUAGE=en
WORK_DIR=~/.ina-device-hub
LOCAL_STORAGE_BASE_DIR=/mnt/...

TURSO_DATABASE_URL=libsql://
TURSO_AUTH_TOKEN=
TURSO_SYNC_INTERVAL=600

S3_ENDPOINT_URL=https://
S3_BUCKET_NAME=
S3_BUCKET_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=

S3_TMP_ENDPOINT_URL=https://***.r2.cloudflarestorage.com
S3_TMP_BUCKET_NAME=
S3_TMP_BUCKET_REGION=auto
S3_TMP_ACCESS_KEY=
S3_TMP_SECRET_KEY=
S3_TMP_BASE_URL=https://{your_temporary_storage_domain}

INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

INSTAGRAM_SENSOR_ID=
INSTAGRAM_CAMERA_ID=
INSTAGRAM_PLANT_POSITION_PROMPT="From left: blueberry, lychee"
INSTAGRAM_ADMIN_USERNAME=inas_technologies.ja

WEATHER_RECORD_ENABLED=true
WEATHER_RECORD_INTERVAL_SECONDS=21600
WEATHER_PROVIDER=open_meteo
WEATHER_LATITUDE=33.90366750991095
WEATHER_LONGITUDE=133.1918432786152
WEATHER_TIMEZONE=Asia/Tokyo
WEATHER_BACKFILL_DAYS=7
WEATHER_OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
WEATHER_FORECAST_URL=https://www.data.jma.go.jp/developer/xml/feed/regular.xml
WEATHER_AREA_NAME=東予
WEATHER_OFFICE_NAME=松山地方気象台
WEATHER_FORECAST_TITLE=府県天気予報
INSTAGRAM_WEATHER_FORECAST_URL=https://www.data.jma.go.jp/developer/xml/feed/regular.xml
INSTAGRAM_WEATHER_AREA_NAME=東予
INSTAGRAM_WEATHER_OFFICE_NAME=松山地方気象台
INSTAGRAM_WEATHER_FORECAST_TITLE=府県天気予報

MQTT_BROKER_URL=localhost
MQTT_BROKER_PORT=1883
MQTT_BROKER_USERNAME=
MQTT_BROKER_PASSWORD=

DEVICE_CONFIG_DEFAULT_NTP_SERVER=pool.ntp.org
DEVICE_CONFIG_DEFAULT_TIMEZONE_OFFSET_SEC=32400
DEVICE_CONFIG_DEFAULT_MOISTURE_THRESHOLD=35

SENSOR_SAVE_IMAGE=false
SENSOR_SAVE_AUDIO=false

TIMELAPSE_INTERVAL=600

# ================================================
# AI settings
# ================================================
AI_ENABLED=true
AI_AGENT_SCHEDULE_START=09:01
AI_IMAGE_ANALYZE_API_KEY=sk-****
# AI_IMAGE_ANALYZE_BASE_URL=
AI_IMAGE_ANALYZE_MODEL=gpt-4o
AI_TEXT_ANALYZE_API_KEY=sk-***
AI_TEXT_ANALYZE_BASE_URL=https://api.deepseek.com
AI_TEXT_ANALYZE_MODEL=deepseek-reasoner


DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url
